  create temporary table "int_product_sales__dbt_tmp085003617407"
  
  
    as
  
  (
    

with transformed_data as (
    select
        order_id,
        product_id,
        p.product_name,
        p.category,
        o.total_amount,
        o.order_date
    from "postgres"."transform"."stg_orders" o
